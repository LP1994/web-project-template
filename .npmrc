#默认包注册表地址（https://registry.npmjs.org/）。可设置为淘宝镜像等加速下载。
#淘宝最新的npm镜像地址：https://registry.npmmirror.com/
#淘宝旧的npm镜像地址（https://registry.npm.taobao.org/）已经停用了，会被重定向为最新的npm镜像地址：https://registry.npmmirror.com/
#registry=https://registry.npmjs.org/

#全局包安装的目录。
prefix=D:\NodeJS\App\node\node_global

#npm下载的包缓存存放目录。
cache=D:\NodeJS\App\node\node_cache

#设置Node.js运行时参数，如内存限制。
node-options="--max-old-space-size=20480"

#npm下载包时，与每个源主机最大并发连接数。默认值为Infinity，也可以设置为10、50、100等等数值。
#别设置太高，会导致相关的系统资源耗尽，导致安装失败！设置成10一般就够了！
maxsockets=10

#控制台输出的日志级别。可选值：silent、error、warn、http、info、verbose、silly。
loglevel=info

#是否显示安装进度条。
progress=true

#HTTP代理服务器地址。
#proxy=http://127.0.0.1:4088

#HTTPS代理服务器地址。
#https-proxy=http://127.0.0.1:4088

#不使用代理的地址列表（支持通配符）。
#noproxy=localhost,127.0.0.1,*.local

#是否严格验证 SSL 证书。设为 false 可绕过证书错误（不安全，仅调试用）。
strict-ssl=true

#等待单个网络请求的超时时间。单位：毫秒。
fetch-timeout=300000

#网络错误或 5xx 响应时的重试次数。
fetch-retries=10

#重试的最小等待间隔。单位：毫秒。
fetch-retry-mintimeout=10000

#重试的最大等待间隔（指数退避）。单位：毫秒。
fetch-retry-maxtimeout=60000

#输出是否带颜色。CI 环境可设为 false 获得纯文本。
color=true

#是否输出 Unicode 字符（如 ✔）。Windows 控制台可能不支持，可设为 false。
unicode=true

#是否输出详细的耗时统计信息。
timing=true

#存放 debug 日志的目录。
#logs-dir=D:\NodeJS\App\node\node_cache\logs

#是否将 package-lock.json 格式化为易读形式。false：表示关闭可减小文件体积。
format-package-lock=true

#用户级 npmrc 文件位置。
userconfig=C:\Users\12278\.npmrc

#npm 存放临时文件的目录。默认值：系统临时目录。
#tmp=D:\NodeJS\App\node\node_cache
