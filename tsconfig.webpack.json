{
  "display": "tsconfig.webpack.json",
  "_version": "1.0.0",
  "_typescript_version": "7.0.2",
  "_description": "这是给基于Webpack及其插件、加载器等等配置的web-project-template使用的适用于WEB一类项目的tsconfig.json。",
  "$schema": "https://json.schemastore.org/tsconfig",
  "docs": "https://www.typescriptlang.org/tsconfig",
  "_tsc_cli": "tsc -p ./tsconfig.webpack.json",
  "extends": "./configures/tsconfig/tsconfig.web.json5",
  "include": [
    "./**/@mf-types/*",
    "./src/**/*.ts",
    "./src/**/*.cts",
    "./src/**/*.mjs",
    "./src/**/*.mts",
    "./src/**/*.tsx",
    "./src/**/*.d.ts",
    "./src/**/*.d.cts",
    "./src/**/*.d.mts",
    "./src/**/*.ts.vue",
    "./src/**/*.cts.vue",
    "./src/**/*.mts.vue",
    "./src/**/*.tsx.vue",
    "./src/**/*.json",
    "./subsystems/**/*.ts",
    "./subsystems/**/*.cts",
    "./subsystems/**/*.mjs",
    "./subsystems/**/*.mts",
    "./subsystems/**/*.tsx",
    "./subsystems/**/*.d.ts",
    "./subsystems/**/*.d.cts",
    "./subsystems/**/*.d.mts",
    "./subsystems/**/*.ts.vue",
    "./subsystems/**/*.cts.vue",
    "./subsystems/**/*.mts.vue",
    "./subsystems/**/*.tsx.vue",
    "./subsystems/**/*.json"
  ],
  "exclude": [
    "./.git",
    "./.idea",
    "**/node_modules/**",
    "./node_modules",
    "./simulation_servers",
    "./simulation_servers/deno/node_modules",
    "./**/*.test.ts",
    "./**/*.test.cts",
    "./**/*.test.mts",
    "./**/*.test.esm.ts",
    "./**/*.test.commonjs.cts",
    "./**/*.test.esm.mts"
  ],
  "ts-node": {
    "compiler": "typescript",
    "compilerHost": false,
    "emit": false,
    "esm": true,
    "experimentalReplAwait": true,
    "experimentalResolver": false,
    "experimentalTsImportSpecifiers": true,
    "files": false,
    "logError": false,
    "preferTsExts": true,
    "pretty": true,
    "skipIgnore": false,
    "swc": false,
    "transpileOnly": false
  },
  "compilerOptions": {
    "target": "es2025",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "baseUrl": "./",
    "declarationDir": "./ts_compiled/",
    "outDir": "./ts_compiled/",
    "tsBuildInfoFile": "./ts_compiled/TSBuildInfo.tsbuildinfo.json5",
    "typeRoots": [
      "./node_modules/@types",
      "./src/custom_declare_types"
    ],
    "paths": {
      "element-ui-css": [
        "./node_modules/element-ui/lib/theme-chalk/index.css"
      ],
      "element-plus-css": [
        "./node_modules/element-plus/dist/index.css"
      ],
      "swiper-css": [
        "./node_modules/swiper/swiper-bundle.min.css"
      ],
      "tslib": [
        "./node_modules/tslib/"
      ],

      "assetsDir/*": [
        "./src/assets/*"
      ],
