{
  "display": "tsconfig.tsx.json",
  "_version": "1.0.0",
  "_typescript_version": "6.0.3",
  "_tsx_version": "4.22.4",
  "_description": "这是给tsx使用的tsconfig.json。该配置扩展自tsconfig.json。",
  "$schema": "https://json.schemastore.org/tsconfig",
  "docs": "https://www.typescriptlang.org/tsconfig",
  "_tsx_docs": "https://github.com/privatenumber/tsx",
  "extends": "./tsconfig.json",
  "include": [
    "./**/@mf-types/*",
    "./**/*.ts",
    "./**/*.cts",
    "./**/*.mts",
    "./**/*.json"
  ],
  "exclude": [
    "./.git",
    "./.idea",
    "**/node_modules/**",
    "./node_modules",
    "./simulation_servers/deno/node_modules"
  ],
  "compileOnSave": true,
  "typeAcquisition": {
    "enable": true,
    "disableFilenameBasedTypeAcquisition": false
  },
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "resolvePackageJsonExports": true,
    "resolvePackageJsonImports": true,
    "allowArbitraryExtensions": true,
    "verbatimModuleSyntax": true,

    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "alwaysStrict": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noPropertyAccessFromIndexSignature": false,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "strictBindCallApply": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": true,
    "allowUmdGlobalAccess": true,

    "noResolve": false,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "sourceMap": false,
    "allowJs": true,
    "checkJs": false,
    "maxNodeModuleJsDepth": 0,
    "disableSizeLimit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "preserveSymlinks": false,
    "experimentalDecorators": false,
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment",
    "moduleDetection": "auto",
    "noLib": false,
    "explainFiles": false,
    "extendedDiagnostics": false,
    "listEmittedFiles": false,
    "traceResolution": false,
    "disableReferencedProjectLoad": false,
    "disableSolutionSearching": false,
    "disableSourceOfProjectReferenceRedirect": false,
    "skipLibCheck": true,
    "assumeChangesOnlyAffectDirectDependencies": true,

    "target": "es2025",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": ".",
    "baseUrl": "./",
    "outDir": "./ts_compiled/",
    "paths": {
      "element-ui-css": [
        "./node_modules/element-ui/lib/theme-chalk/index.css"
      ],
      "element-plus-css": [
        "./node_modules/element-plus/dist/index.css"
      ],
      "swiper-css": [
        "./node_modules/swiper/swiper-bundle.min.css"
      ],
      "tslib": [
        "./node_modules/tslib/"
      ],

      "assetsDir/*": [
        "./src/assets/*"
      ],
      "docDir/*": [
        "./src/assets/doc/*"
      ],
      "csonDir/*": [
        "./src/assets/doc/cson/*"
      ],
      "csvDir/*": [
        "./src/assets/doc/csv/*"
      ],
      "jsonDir/*": [
        "./src/assets/doc/json/*"
      ],
      "json5Dir/*": [
        "./src/assets/doc/json5/*"
      ],
      "tomlDir/*": [
        "./src/assets/doc/toml/*"
      ],
      "tsvDir/*": [
        "./src/assets/doc/tsv/*"
      ],
      "txtDir/*": [
        "./src/assets/doc/txt/*"
      ],
      "xmlDir/*": [
        "./src/assets/doc/xml/*"
      ],
      "yamlDir/*": [
        "./src/assets/doc/yaml/*"
      ],
      "fontsDir/*": [
        "./src/assets/fonts/*"
      ],
      "imgDir/*": [
        "./src/assets/img/*"
      ],
      "musicDir/*": [
        "./src/assets/music/*"
      ],
      "videosDir/*": [
        "./src/assets/videos/*"
      ],
      "gQLAPIDir/*": [
        "./src/graphQL/api/*"
      ],
      "nativeComponentsDir/*": [
        "./src/native_components/*"
      ],
      "pagesDir/*": [
        "./src/pages/*"
      ],
      "pwaManifestDir/*": [
        "./src/pwa_manifest/*"
      ],
      "stylesDir/*": [
        "./src/styles/*"
      ],
      "cssDir/*": [
        "./src/styles/css/*"
      ],
      "lessDir/*": [
        "./src/styles/less/*"
      ],
      "postcssDir/*": [
        "./src/styles/postcss/*"
      ],
      "sassDir/*": [
        "./src/styles/sass/*"
      ],
      "scssDir/*": [
        "./src/styles/scss/*"
      ],
      "stylusDir/*": [
        "./src/styles/stylus/*"
      ],
      "templateDir/*": [
        "./src/template/*"
      ],
      "ejsDir/*": [
        "./src/template/ejs/*"
      ],
      "handlebarsDir/*": [
        "./src/template/handlebars/*"
      ],
      "htmlDir/*": [
        "./src/template/html/*"
      ],
      "markdownDir/*": [
        "./src/template/markdown/*"
      ],
      "mustacheDir/*": [
        "./src/template/mustache/*"
      ],
      "pug_jadeDir/*": [
        "./src/template/pug_jade/*"
      ],
      "toolsDir/*": [
        "./src/tools/*"
      ],
      "jsDir/*": [
        "./src/tools/js/*"
      ],
      "tsDir/*": [
        "./src/tools/ts/*"
      ],
      "currency_toolsDir/*": [
        "./src/tools/js/currency_tools/*"
      ],
      "universal_toolsDir/*": [
        "./src/tools/ts/universal_tools/*"
      ],
      "wasmDir/*": [
        "./src/wasm/build/*"
      ],
      "webComponentsDir/*": [
        "./src/web_components/*"
      ],
      "workersDir/*": [
        "./src/workers/*"
      ],
      "serviceWorkersDir/*": [
        "./src/workers/service_workers/*"
      ],
      "sharedWorkersDir/*": [
        "./src/workers/shared_workers/*"
      ],
      "workersToolsDir/*": [
        "./src/workers/tools/*"
      ],
      "webWorkersDir/*": [
        "./src/workers/web_workers/*"
      ],

      "deno_std/*": [
        "https://deno.land/std/*"
      ],
      "deno_std_encoding/*": [
        "https://deno.land/std/encoding/*"
      ],
      "deno_std_io/*": [
        "https://deno.land/std/io/*"
      ],
      "deno_std_media_types": [
        "https://deno.land/std/media_types/mod.ts"
      ],
      "deno_std_path": [
        "https://deno.land/std/path/mod.ts"
      ],

      "deno_x/*": [
        "https://deno.land/x/*"
      ],
      "deno_x_corejs": [
        "https://deno.land/x/corejs@v3.49.0/index.js"
      ],
      "deno_x_ejs": [
        "https://deno.land/x/dejs/mod.ts"
      ],
      "deno_x_mongo": [
        "https://deno.land/x/mongo/mod.ts"
      ],

      "esm_sh/*": [
        "https://esm.sh/*"
      ],
      "esm_sh_graphql": [
        "https://esm.sh/graphql"
      ],

      "preact/*": [
        "https://cdn.skypack.dev/preact/*"
      ],
      "preact_jsx-runtime": [
        "https://cdn.skypack.dev/preact/jsx-runtime?dts"
      ],
      "preact_jsx-dev-runtime": [
        "https://cdn.skypack.dev/preact/jsx-dev-runtime?dts"
      ],

      "deno_src/*": [
        "./simulation_servers/deno/src/*"
      ],
      "configures/*": [
        "./simulation_servers/deno/src/configures/*"
      ],
      "route_map_config/*": [
        "./simulation_servers/deno/src/configures/route_map_config/*"
      ],
      "database/*": [
        "./simulation_servers/deno/src/database/*"
      ],
      "deno_db/*": [
        "./simulation_servers/deno/src/database/deno_db/*"
      ],
      "firebase/*": [
        "./simulation_servers/deno/src/database/firebase/*"
      ],
      "graphql/*": [
        "./simulation_servers/deno/src/database/graphql/*"
      ],
      "mongo/*": [
        "./simulation_servers/deno/src/database/mongo/*"
      ],
      "mysql/*": [
        "./simulation_servers/deno/src/database/mysql/*"
      ],
      "postgres/*": [
        "./simulation_servers/deno/src/database/postgres/*"
      ],
      "sqlite/*": [
        "./simulation_servers/deno/src/database/sqlite/*"
      ],
      "supabase/*": [
        "./simulation_servers/deno/src/database/supabase/*"
      ],
      "public/*": [
        "./simulation_servers/deno/src/public/*"
      ],
      "routers/*": [
        "./simulation_servers/deno/src/routers/*"
      ],
      "servers/*": [
        "./simulation_servers/deno/src/servers/*"
      ],
      "services/*": [
        "./simulation_servers/deno/src/services/*"
      ],
      "ssr/*": [
        "./simulation_servers/deno/src/ssr/*"
      ],
      "template/*": [
        "./simulation_servers/deno/src/template/*"
      ],
      "ejs/*": [
        "./simulation_servers/deno/src/template/ejs/*"
      ],
      "handlebars/*": [
        "./simulation_servers/deno/src/template/handlebars/*"
      ],
      "html/*": [
        "./simulation_servers/deno/src/template/html/*"
      ],
      "markdown/*": [
        "./simulation_servers/deno/src/template/markdown/*"
      ],
      "mustache/*": [
        "./simulation_servers/deno/src/template/mustache/*"
      ],
      "pug_jade/*": [
        "./simulation_servers/deno/src/template/pug_jade/*"
      ],
      "tools/*": [
        "./simulation_servers/deno/src/tools/*"
      ],
      "third_party_modules/*": [
        "./simulation_servers/deno/src/tools/third_party_modules/*"
      ],
      "universal_tool_for_deno/*": [
        "./simulation_servers/deno/src/tools/universal_tool_for_deno/*"
      ],
      "static/*": [
        "./simulation_servers/deno/static/*"
      ],
      "test/*": [
        "./simulation_servers/deno/test/*"
      ],
      "upload/*": [
        "./simulation_servers/deno/upload/*"
      ],
      "web/*": [
        "./simulation_servers/deno/web/*"
      ],

      "GSD2TSTD": [
        "./src/graphql_schema_definition_to_ts_type_definition/GSD2TSTD.esm.mts"
      ],
      "MF_v2_RuntimeAPI": [
        "./src/ModuleFederation_v2_RuntimeAPI.esm.mts"
      ],
      "MF_v2_RegisterRemotes": [
        "./src/ModuleFederation_v2_RegisterRemotes.se.esm.mts"
      ]
    }
  }
}
